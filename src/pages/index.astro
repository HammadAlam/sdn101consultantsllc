---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<main>
			<!-- Hero -->
			<section class="hero">
				<div class="hero-inner">
					<div class="hero-badge">LMS & Training Operations Consulting</div>
					<h1>Certification Programs.<br/>Learning Platforms.<br/>Done Right.</h1>
					<p class="tagline">
						SDN101 Consultants LLC helps technology companies scale their training programs,
						manage learning platforms, and operate certification programs — with precision,
						automation, and measurable results.
					</p>
					<div class="cta-group">
						<a href="/contact" class="btn-primary">Get in Touch</a>
						<a href="/services" class="btn-secondary">Our Services</a>
					</div>
				</div>
			</section>

			<!-- Stats -->
			<section class="stats">
				<div class="stats-inner">
					<div class="stat">
						<span class="stat-num">25,000+</span>
						<span class="stat-lbl">Certified Engineers Supported</span>
					</div>
					<div class="stat">
						<span class="stat-num">400%</span>
						<span class="stat-lbl">Certification Program Growth</span>
					</div>
					<div class="stat">
						<span class="stat-num">90%</span>
						<span class="stat-lbl">Reduction in Processing Time</span>
					</div>
					<div class="stat">
						<span class="stat-num">60%</span>
						<span class="stat-lbl">Cost Savings via Consolidation</span>
					</div>
				</div>
			</section>

			<!-- Services -->
			<section class="services">
				<div class="services-inner">
					<h2>What We Do</h2>
					<div class="service-grid">
						<div class="service-card">
							<div class="card-head"><div class="service-icon">🎓</div><h3>LMS Administration</h3></div>
							<p>End-to-end management of enterprise learning platforms — SkillJar, Teachable, Absorb, Docebo — including migrations, integrations, and compliance reporting.</p>
						</div>
						<div class="service-card">
							<div class="card-head"><div class="service-icon">📋</div><h3>Certification Program Management</h3></div>
							<p>Launch and operate technical certification programs at scale — exam logistics, Pearson VUE coordination, Credly badge issuance, and database management.</p>
						</div>
						<div class="service-card">
							<div class="card-head"><div class="service-icon">⚙️</div><h3>Training Operations</h3></div>
							<p>Day-to-day operational management of ILT and self-paced programs — scheduling, vendor coordination, learner support, and stakeholder reporting.</p>
						</div>
						<div class="service-card">
							<div class="card-head"><div class="service-icon">🤖</div><h3>Process Automation</h3></div>
							<p>Automate certificate generation, enrollment workflows, and reporting pipelines — reducing manual effort and eliminating operational bottlenecks.</p>
						</div>
						<div class="service-card">
							<div class="card-head"><div class="service-icon">🔀</div><h3>Platform Migration</h3></div>
							<p>Migrate between LMS platforms with zero learner disruption — full data migration, integration setup, and go-live support.</p>
						</div>
						<div class="service-card">
							<div class="card-head"><div class="service-icon">📈</div><h3>Program Scaling</h3></div>
							<p>Build the operational infrastructure to grow certification programs from hundreds to tens of thousands of learners — without proportional headcount growth.</p>
						</div>
					</div>
					<div class="services-link">
						<a href="/services">View detailed services →</a>
					</div>
				</div>
			</section>

			<!-- Why -->
			<section class="why">
				<div class="why-inner">
					<div class="why-text">
						<h2>Why SDN101 Consultants</h2>
						<p>We're not a large agency with layers of overhead. We're experienced learning operations practitioners who work directly with your team to solve real problems — fast.</p>
						<p>No account managers. No junior staff on your project. You get senior expertise, clear communication, and outcomes you can measure.</p>
						<ul>
							<li>5+ years running enterprise certification programs at scale</li>
							<li>Hands-on experience with SkillJar, Pearson VUE, Credly, Absorb, Docebo</li>
							<li>Proven automation — 90% reduction in manual processing time</li>
							<li>Fixed-fee engagements — no surprise invoices</li>
						</ul>
						<a href="/about" class="btn-secondary" style="display:inline-block; margin-top:1.2em;">More About Us</a>
					</div>
					<div class="why-stats">
						<div class="stat-card">
							<span class="stat-num">87%</span>
							<span class="stat-lbl">Reduction in learner support volume</span>
						</div>
						<div class="stat-card">
							<span class="stat-num">60%</span>
							<span class="stat-lbl">Platform cost savings delivered</span>
						</div>
						<div class="stat-card">
							<span class="stat-num">4.7</span>
							<span class="stat-lbl">Average CSAT score achieved</span>
						</div>
						<div class="stat-card">
							<span class="stat-num">5+</span>
							<span class="stat-lbl">Years of enterprise LMS experience</span>
						</div>
					</div>
				</div>
			</section>

			<!-- CTA -->
			<section class="final-cta">
				<div class="final-cta-inner">
					<h2>Ready to scale your training program?</h2>
					<p>Let's talk about your specific situation — no sales pitch, just a conversation about what you need.</p>
					<a href="/contact" class="btn-primary">Get in Touch</a>
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>

<style>
	main { width: 100%; max-width: 100%; padding: 0; margin: 0; }

	/* Hero */
	.hero {
		background: linear-gradient(135deg, rgb(var(--black)) 0%, #0f2057 100%);
		padding: 5em 1.5em 4.5em;
	}
	.hero-inner { max-width: 800px; margin: 0 auto; text-align: center; }
	.hero-badge {
		display: inline-block;
		background: rgba(147,197,253,0.15);
		color: #93c5fd;
		border: 1px solid rgba(147,197,253,0.3);
		padding: 0.4em 1em;
		border-radius: 999px;
		font-size: 0.8em;
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		margin-bottom: 1.2em;
	}
	.hero h1 { font-size: 3em; color: white; line-height: 1.15; margin-bottom: 0.6em; }
	.tagline { font-size: 1.1em; color: #cbd5e1; max-width: 620px; margin: 0 auto 2em; line-height: 1.75; }
	.cta-group { display: flex; gap: 1em; justify-content: center; flex-wrap: wrap; }
	.btn-primary {
		background: #2563eb; color: white; padding: 0.8em 1.8em;
		border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.95em;
	}
	.btn-primary:hover { background: #1d4ed8; color: white; }
	.btn-secondary {
		border: 2px solid #93c5fd; color: #93c5fd; padding: 0.8em 1.8em;
		border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.95em;
	}
	.btn-secondary:hover { background: rgba(147,197,253,0.1); color: #93c5fd; }

	/* Stats */
	.stats { background: rgb(var(--black)); padding: 3em 1.5em; }
	.stats-inner { max-width: 960px; margin: 0 auto; display: grid; grid-template-columns: repeat(4,1fr); gap: 1em; }
	.stat { text-align: center; padding: 1em; }
	.stat-num { display: block; font-size: 2.2em; font-weight: 700; color: #93c5fd; line-height: 1; margin-bottom: 0.3em; }
	.stat-lbl { font-size: 0.8em; color: rgb(var(--gray-light)); line-height: 1.4; }

	/* Services */
	.services { padding: 4em 1.5em; }
	.services-inner { max-width: 960px; margin: 0 auto; }
	.services h2 { font-size: 1.9em; margin-bottom: 1.2em; color: rgb(var(--black)); }
	.service-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.4em; margin-bottom: 1.5em; }
	.service-card { border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.4em; }
	.service-card:hover { border-color: var(--accent); }
	.card-head { display: flex; align-items: center; gap: 0.5em; margin-bottom: 0.6em; }
	.service-icon { font-size: 1.8em; line-height: 1; flex-shrink: 0; }
	.service-card h3, .who-card h3 { margin: 0; font-size: 0.95em; font-weight: 700; color: rgb(var(--black)); }
	.service-card p { font-size: 0.88em; color: rgb(var(--gray)); line-height: 1.65; margin: 0; }
	.services-link { text-align: right; }
	.services-link a { color: var(--accent); font-weight: 600; text-decoration: none; font-size: 0.95em; }
	.services-link a:hover { text-decoration: underline; }

	/* Why */
	.why { background: rgb(var(--black)); padding: 4em 1.5em; }
	.why-inner { max-width: 960px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr; gap: 4em; align-items: center; }
	.why-text h2 { font-size: 1.9em; color: white; margin-bottom: 0.8em; }
	.why-text p { color: #cbd5e1; font-size: 0.95em; line-height: 1.75; margin-bottom: 0.8em; }
	.why-text ul { padding-left: 1.2em; margin: 0; }
	.why-text li { color: #94a3b8; font-size: 0.9em; margin-bottom: 0.4em; line-height: 1.6; }
	.why-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5em; }
	.stat-card {
		background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);
		border-radius: 10px; padding: 1.2em; text-align: center;
	}
	.stat-card .stat-num { display: block; font-size: 2em; font-weight: 700; color: #93c5fd; line-height: 1; margin-bottom: 0.3em; }
	.stat-card .stat-lbl { font-size: 0.78em; color: #94a3b8; line-height: 1.4; }

	/* Final CTA */
	.final-cta { padding: 4em 1.5em; background: #eff6ff; text-align: center; }
	.final-cta-inner { max-width: 600px; margin: 0 auto; }
	.final-cta h2 { font-size: 1.7em; color: rgb(var(--black)); margin-bottom: 0.5em; }
	.final-cta p { color: rgb(var(--gray)); font-size: 1em; margin-bottom: 1.5em; }
	.final-cta .btn-primary { background: var(--accent); }
	.final-cta .btn-primary:hover { background: var(--accent-dark); color: white; }

	@media (max-width: 720px) {
		.hero h1 { font-size: 2em; }
		.stats-inner { grid-template-columns: 1fr 1fr; }
		.service-grid { grid-template-columns: 1fr; }
		.why-inner { grid-template-columns: 1fr; gap: 2em; }
		.why-stats { grid-template-columns: 1fr 1fr; }
	}
</style>
