---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Services — SDN101 Consultants LLC" description="LMS administration, certification program management, training operations, and process automation." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<div class="page-header-inner">
					<h1>Services</h1>
					<p>Specialized consulting across the full learning operations lifecycle.</p>
				</div>
			</div>

			<div class="page-inner">

				<div class="service">
					<h2>LMS Administration & Platform Management</h2>
					<p>Full administration of enterprise learning platforms — configuration, integrations, content publishing, compliance reporting, and vendor management. We handle the operational complexity so your team can focus on content and learners.</p>
					<ul>
						<li>Platform setup and configuration (SkillJar, Teachable, Absorb, Docebo, Evolve)</li>
						<li>LMS migrations with zero learner disruption</li>
						<li>Integration management (Salesforce, Credly, Pearson VUE, Proctorio)</li>
						<li>SCORM / AICC content support and troubleshooting</li>
						<li>GDPR compliance, data retention, and audit trails</li>
						<li>Vendor PoC evaluation and recommendation</li>
					</ul>
				</div>

				<div class="service">
					<h2>Certification Program Management</h2>
					<p>End-to-end management of technical certification programs — from exam logistics and proctoring operations to badge issuance and database management. Proven experience managing programs with 25,000+ certified engineers.</p>
					<ul>
						<li>Pearson VUE exam scheduling and issue resolution</li>
						<li>Credly digital badge configuration and issuance</li>
						<li>Certification database management and reconciliation</li>
						<li>Exam integrity controls and anti-cheating processes</li>
						<li>Program metrics reporting and stakeholder dashboards</li>
						<li>Multi-tier certification track management</li>
					</ul>
				</div>

				<div class="service">
					<h2>Training Operations Management</h2>
					<p>Day-to-day operational management of instructor-led and self-paced training programs — scheduling, vendor coordination, learner support, and workflow automation that keeps programs running efficiently at scale.</p>
					<ul>
						<li>ILT session scheduling and calendar management</li>
						<li>Learner support inbox management and SLA adherence</li>
						<li>Vendor management (Skilljar, Camtasia, HeyGen, Lucidchart, Credly)</li>
						<li>Executive reporting and program KPI dashboards</li>
						<li>Cross-functional stakeholder communication</li>
						<li>Private and custom course coordination</li>
					</ul>
				</div>

				<div class="service">
					<h2>Process Automation & Workflow Design</h2>
					<p>Design and implementation of automated workflows that eliminate manual bottlenecks, reduce support volume, and improve operational efficiency across training programs.</p>
					<ul>
						<li>Certificate generation and delivery automation</li>
						<li>Enrollment and exam workflow automation</li>
						<li>AI-assisted content and reporting workflows</li>
						<li>Support deflection via documentation and self-service resources</li>
						<li>Marketing and campaign timing coordination</li>
					</ul>
				</div>

				<div class="service">
					<h2>Program Scaling & Growth Operations</h2>
					<p>Strategic and operational support for training programs undergoing rapid growth — building the infrastructure, processes, and automation needed to scale without proportional headcount growth.</p>
					<ul>
						<li>Scaled delivery model design (self-paced, ILT, hybrid)</li>
						<li>Partner and GSI training program development</li>
						<li>Content launch readiness and go-live coordination</li>
						<li>Cost optimization through platform consolidation</li>
						<li>CSAT improvement through analytics and process changes</li>
					</ul>
				</div>

				<div class="cta-box">
					<h2>Ready to scale your training program?</h2>
					<p>Tell us about your situation and we'll recommend a practical path forward.</p>
					<a href="/contact" class="btn-primary">Get in Touch</a>
				</div>

			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		background: linear-gradient(135deg, rgb(var(--black)) 0%, #0f2057 100%);
		padding: 3.5em 1.5em;
	}
	.page-header-inner { max-width: 760px; margin: 0 auto; }
	.page-header h1 { color: white; font-size: 2.4em; margin-bottom: 0.3em; }
	.page-header p { color: #cbd5e1; font-size: 1.05em; margin: 0; }
	.page-inner { max-width: 760px; margin: 0 auto; padding: 3em 1.5em; }
	.service { margin-bottom: 2.5em; padding-bottom: 2.5em; border-bottom: 1px solid #e2e8f0; }
	.service:last-of-type { border-bottom: none; }
	h2 { font-size: 1.3em; color: var(--accent); margin-bottom: 0.5em; }
	p { color: rgb(var(--gray-dark)); line-height: 1.75; margin-bottom: 0.8em; font-size: 0.95em; }
	ul { padding-left: 1.3em; margin: 0; }
	li { font-size: 0.9em; color: rgb(var(--gray)); margin-bottom: 0.35em; line-height: 1.6; }
	.cta-box { background: #eff6ff; border-radius: 10px; padding: 2.5em; text-align: center; margin-top: 2em; }
	.cta-box h2 { font-size: 1.4em; color: rgb(var(--black)); margin-bottom: 0.4em; }
	.cta-box p { color: rgb(var(--gray)); margin-bottom: 1.2em; }
	.btn-primary {
		background: var(--accent); color: white; padding: 0.8em 1.8em;
		border-radius: 6px; text-decoration: none; font-weight: 600; font-size: 0.95em;
	}
	.btn-primary:hover { background: var(--accent-dark); color: white; }
</style>
