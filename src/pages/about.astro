---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — SDN101 Consultants LLC" description="About SDN101 Consultants LLC — technology consulting for small businesses." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<div class="page-header-inner">
					<h1>About SDN101 Consultants LLC</h1>
					<p>Senior technology expertise. Small business focus. No agency overhead.</p>
				</div>
			</div>

			<div class="page-inner">
				<h2>Who We Are</h2>
				<p>
					SDN101 Consultants LLC is a New Jersey-based independent technology consulting firm
					founded to bring enterprise-grade expertise to small and mid-size businesses — at a
					fraction of the cost and complexity.
				</p>
				<p>
					We are practitioners, not account managers. Our team brings direct hands-on experience
					across cloud architecture, network design, and learning technology — built over three decades
					of working with global technology companies and complex enterprise environments.
				</p>

				<h2>Our Background</h2>
				<p>
					Our principals include an AWS Certified Solutions Architect with deep experience in
					cloud infrastructure, cost optimization, disaster recovery, and network architecture —
					and a learning technology specialist who has built and scaled certification programs
					serving over 25,000 engineers worldwide.
				</p>
				<p>
					Together we cover the full stack of technology challenges small businesses face:
					from cloud cost and resilience to the learning programs that keep their teams sharp
					and their customers certified.
				</p>

				<h2>Our Approach</h2>
				<p>
					We work on a fixed-fee or retainer basis — no surprise invoices, no scope creep
					without your sign-off. Every engagement starts with a clear understanding of your
					situation, a defined scope, and measurable outcomes.
				</p>
				<p>
					We believe the best consulting feels like having a senior technical partner on call —
					someone who tells you what they'd do if it were their own business, not what generates
					the most billable hours.
				</p>

				<h2>Contact</h2>
				<p>
					Reach us at <a href="mailto:sdn101consultants@gmail.com">sdn101consultants@gmail.com</a>.
					We respond within one business day.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		background: linear-gradient(135deg, rgb(var(--black)) 0%, #0f2057 100%);
		padding: 3.5em 1.5em;
	}
	.page-header-inner { max-width: 760px; margin: 0 auto; }
	.page-header h1 { color: white; font-size: 2.4em; margin-bottom: 0.3em; }
	.page-header p { color: #cbd5e1; font-size: 1.05em; margin: 0; }

	.page-inner { max-width: 720px; margin: 0 auto; padding: 3em 1.5em; }
	h2 { font-size: 1.3em; color: var(--accent); margin-top: 1.8em; margin-bottom: 0.5em; }
	p { color: rgb(var(--gray-dark)); line-height: 1.8; font-size: 0.97em; margin-bottom: 0.8em; }
	a { color: var(--accent); text-decoration: none; }
	a:hover { text-decoration: underline; }
</style>
