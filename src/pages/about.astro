---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About — SDN101 Consultants LLC" description="About SDN101 Consultants LLC — LMS and training operations consulting." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<div class="page-header-inner">
					<h1>About SDN101 Consultants LLC</h1>
					<p>Senior learning operations expertise. No agency overhead.</p>
				</div>
			</div>

			<div class="page-inner">
				<h2>Who We Are</h2>
				<p>
					SDN101 Consultants LLC is a New Jersey-based independent consulting firm
					specializing in learning management systems, certification program management,
					and training operations for technology companies.
				</p>
				<p>
					We are practitioners, not account managers. Our principal consultant brings
					direct hands-on experience building and scaling enterprise certification programs
					— managing the platforms, processes, vendors, and automations that make large
					training programs run smoothly.
				</p>

				<h2>Our Background</h2>
				<p>
					Our principal has 5+ years of experience running enterprise LMS operations,
					having scaled a technical certification program from 5,000 to over 25,000
					certified engineers — a 400% increase — while simultaneously reducing support
					volume by 87%, cutting operational costs by 60%, and improving learner
					satisfaction from 4.2 to 4.7 CSAT.
				</p>
				<p>
					We have deep hands-on experience with SkillJar, Teachable, Absorb, Docebo,
					Pearson VUE, Credly, Proctorio, Salesforce, and Evolve — across migrations,
					integrations, compliance, and automation.
				</p>

				<h2>How We Work</h2>
				<p>
					We engage on a fixed-fee or retainer basis — no surprise invoices, no scope
					creep without your sign-off. Every engagement starts with a clear understanding
					of your situation, a defined scope, and measurable outcomes.
				</p>
				<p>
					We believe the best consulting feels like having a senior operations partner
					embedded in your team — someone who takes ownership, not just gives advice.
				</p>

				<h2>Contact</h2>
				<p>
					Reach us at <a href="mailto:sdn101consultants@gmail.com">sdn101consultants@gmail.com</a>.
					We respond within one business day.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header {
		background: linear-gradient(135deg, rgb(var(--black)) 0%, #0f2057 100%);
		padding: 3.5em 1.5em;
	}
	.page-header-inner { max-width: 760px; margin: 0 auto; }
	.page-header h1 { color: white; font-size: 2.4em; margin-bottom: 0.3em; }
	.page-header p { color: #cbd5e1; font-size: 1.05em; margin: 0; }
	.page-inner { max-width: 720px; margin: 0 auto; padding: 3em 1.5em; }
	h2 { font-size: 1.3em; color: var(--accent); margin-top: 1.8em; margin-bottom: 0.5em; }
	p { color: rgb(var(--gray-dark)); line-height: 1.8; font-size: 0.97em; margin-bottom: 0.8em; }
	a { color: var(--accent); text-decoration: none; }
	a:hover { text-decoration: underline; }
</style>
