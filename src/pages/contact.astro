---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Contact — SDN101 Consultants LLC" description="Get in touch with SDN101 Consultants LLC." />
	</head>
	<body>
		<Header />
		<main>
			<div class="page-inner">
				<h1>Get in Touch</h1>
				<p class="lead">
					Interested in working together? Reach out and we'll respond within one business day.
				</p>

				<div class="contact-grid">
					<div class="contact-info">
						<h2>Contact</h2>
						<p><strong>Email</strong><br/>
						<a href="mailto:info@sdn101consultants.com">info@sdn101consultants.com</a></p>

						<p><strong>Location</strong><br/>
						New Jersey, USA<br/>
						Available for remote engagements nationwide</p>

						<p><strong>Engagement Types</strong><br/>
						Project-based · Retainer · Short-term contracts</p>
					</div>

					<div class="contact-form">
						<h2>Send a Message</h2>
						<form action="mailto:info@sdn101consultants.com" method="get" enctype="text/plain">
							<label for="name">Name</label>
							<input type="text" id="name" name="name" placeholder="Your name" required />

							<label for="company">Company</label>
							<input type="text" id="company" name="company" placeholder="Your company" />

							<label for="subject">Subject</label>
							<input type="text" id="subject" name="subject" placeholder="Brief description of your need" required />

							<label for="body">Message</label>
							<textarea id="body" name="body" rows="5" placeholder="Tell us about your training operations challenge..."></textarea>

							<button type="submit">Send Message</button>
						</form>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-inner {
		max-width: 900px;
		margin: 0 auto;
		padding: 3em 1.5em;
	}
	h1 {
		font-size: 2.2em;
		margin-bottom: 0.3em;
	}
	.lead {
		font-size: 1.1em;
		color: rgb(var(--gray));
		margin-bottom: 2.5em;
	}
	.contact-grid {
		display: grid;
		grid-template-columns: 1fr 1.6fr;
		gap: 3em;
		align-items: start;
	}
	h2 {
		font-size: 1.2em;
		color: var(--accent);
		margin-bottom: 1em;
	}
	.contact-info p {
		font-size: 0.95em;
		line-height: 1.7;
		margin-bottom: 1.2em;
		color: rgb(var(--gray-dark));
	}
	.contact-info a {
		color: var(--accent);
		text-decoration: none;
	}
	.contact-info a:hover { text-decoration: underline; }

	form {
		display: flex;
		flex-direction: column;
		gap: 0.8em;
	}
	label {
		font-size: 0.85em;
		font-weight: 600;
		color: rgb(var(--gray-dark));
		margin-bottom: -0.4em;
	}
	input, textarea {
		padding: 0.7em 0.9em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		font-size: 0.95em;
		font-family: inherit;
		color: rgb(var(--gray-dark));
		width: 100%;
	}
	input:focus, textarea:focus {
		outline: 2px solid var(--accent);
		border-color: var(--accent);
	}
	button {
		background: var(--accent);
		color: white;
		border: none;
		padding: 0.8em 1.5em;
		border-radius: 6px;
		font-size: 0.95em;
		font-weight: 600;
		cursor: pointer;
		margin-top: 0.4em;
	}
	button:hover { background: var(--accent-dark); }

	@media (max-width: 720px) {
		.contact-grid { grid-template-columns: 1fr; gap: 2em; }
	}
</style>
