---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<strong>SDN101 Consultants LLC</strong>
			<span>New Jersey, USA</span>
		</div>
		<div class="footer-contact">
			<a href="mailto:info@sdn101consultants.com">info@sdn101consultants.com</a>
		</div>
		<div class="footer-copy">
			&copy; {today.getFullYear()} SDN101 Consultants LLC. All rights reserved.
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 2.5em 1.5em;
		background: rgb(var(--black));
		color: rgb(var(--gray-light));
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.6em;
		text-align: center;
	}
	.footer-brand {
		display: flex;
		flex-direction: column;
		gap: 0.2em;
		font-size: 0.95em;
	}
	.footer-brand strong {
		color: white;
		font-size: 1em;
	}
	.footer-contact a {
		color: #93c5fd;
		text-decoration: none;
		font-size: 0.9em;
	}
	.footer-contact a:hover {
		text-decoration: underline;
	}
	.footer-copy {
		font-size: 0.8em;
		color: rgb(var(--gray));
		margin-top: 0.4em;
	}
</style>
