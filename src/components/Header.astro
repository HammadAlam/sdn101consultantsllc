---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="brand"><img src="/logo.svg" alt="SDN101 Consultants LLC" height="44" /></a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/services">Services</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<HeaderLink href="/contact">Contact</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 1.5em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 8%);
	}
	h2 {
		margin: 0;
		font-size: 1.1em;
		font-weight: 700;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: rgb(var(--black));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 960px;
		margin: 0 auto;
		padding: 0.3em 0;
	}
	nav a {
		padding: 0.5em 0.6em;
		color: rgb(var(--gray-dark));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
	}
	a.brand {
		padding: 0.2em 0;
		border-bottom: none;
		display: flex;
		align-items: center;
	}
	a.brand img {
		height: 38px;
		display: block;
	}
	nav a.active {
		border-bottom-color: var(--accent);
		color: var(--accent);
	}
	@media (max-width: 720px) {
		h2 { font-size: 0.95em; }
		nav a { padding: 0.6em 0.4em; font-size: 0.85em; }
	}
</style>
